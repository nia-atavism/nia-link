# ============================================
# Nia-Link Environment Configuration
# ============================================

# Application
APP_NAME=Nia-Link
DEBUG=false

# API Authentication (comma-separated keys)
API_KEYS=your-secret-api-key-here

# Scraper Settings
SCRAPER_TIMEOUT=30
MAX_CONTENT_LENGTH=2000000

# Browser Settings
HEADLESS=true
BROWSER_TYPE=chromium  # chromium, firefox, webkit

# Path Settings (empty = use defaults)
REGISTRY_DIR=
TEMP_DIR=
SESSION_DIR=

# Proxy (empty = direct connection)
PROXY_URL=
PROXY_POOL=  # Comma-separated proxy URLs for rotation
PROXY_ROTATION=round_robin  # round_robin / random
# Examples:
# PROXY_URL=http://user:pass@proxy-server:8080
# PROXY_POOL=http://proxy1:8080,http://proxy2:8080,socks5://proxy3:1080

# Concurrency & Retry
MAX_CONCURRENCY=10
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0

# Rate Limiting (0 = unlimited)
RATE_LIMIT_RPM=60

# CORS Allowed Origins (comma-separated, "*" = allow all)
CORS_ORIGINS=*

# Task Queue
QUEUE_MAX_SIZE=100

# CAPTCHA Solving (empty = disabled)
CAPTCHA_PROVIDER=  # 2captcha / anticaptcha
CAPTCHA_API_KEY=
